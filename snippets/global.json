{
  "Date": {
    "prefix": "date",
    "body": "$CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE"
  },
  "Time": {
    "prefix": "time",
    "body": "$CURRENT_HOUR:$CURRENT_MINUTE"
  },
  "Datetime": {
    "prefix": "htime",
    "body": "$CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATET$CURRENT_HOUR:$CURRENT_MINUTE:$CURRENT_SECOND+10:00"
  }
}