      "<summary> ${1:PromptName} </summary>",
      "<hr/>",
      "<blockquote> ${2:PromptBody}</blockquote>",
      "<b>Notes:</b>",
      "<p><ul><li>${3:PromptNotes1}</li><li>${4:PromptNotes2}</li></ul></p>",
      "</details>"
    ],
    "prefix": "prompt-notes"
